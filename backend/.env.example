# PricingAgent — Environment Variables
# Copy this file to .env and fill in your values

# ── Bright Data (required for live mode) ──────────────────────────────────
# Get your free key at: https://brightdata.com/products/serp-api
BRIGHT_DATA_API_KEY=

# ── Anthropic (required for live mode) ────────────────────────────────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-5

# ── Optional settings ─────────────────────────────────────────────────────
# Leave blank to use defaults shown
CHECK_INTERVAL_HOURS=2       # How often to check prices automatically
AUTO_REPRICE=false           # Never set to true without testing first
SLACK_WEBHOOK_URL=           # Optional: get alerts in Slack
